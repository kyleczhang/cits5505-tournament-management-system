# Flask
FLASK_APP=run:app
FLASK_ENV=development
# Used to sign session cookies and CSRF tokens; replace with a long random value.
SECRET_KEY=change-me-to-a-long-random-string

# Database (relative to instance/)
DATABASE_URL=sqlite:///criktrack.sqlite3

# Auth — set to a secret value to gate organizer sign-up
ORGANIZER_INVITE_CODE=criktrack-organizer-2026

# External APIs (leave blank to disable; the UI gracefully falls back)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GEOCODING_API_KEY=
CRICKETDATA_API_KEY=

# TTL for the in-process live-feed cache before re-hitting the upstream API.
LIVE_FEED_CACHE_SECONDS=30
# Frontend polling interval for the live widget, in ms.
LIVE_FEED_POLL_MS=30000
